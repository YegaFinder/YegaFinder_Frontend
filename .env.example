
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Set to "true" only against a backend running with TEST_MODE=true
# (transactional email disabled) — surfaces OTP codes directly in the
# UI instead of the user waiting on an email that isn't being sent.
# Leave unset (or "false") against any real environment.
NEXT_PUBLIC_TEST_MODE=false

# Opt-in escape hatch for src/lib/hooks/useImageUpload.ts's stub
# implementation to keep working in a production build. Should never be
# set to "true" once the real presigned-upload endpoint is wired up.
# NEXT_PUBLIC_ALLOW_STUB_UPLOAD=true